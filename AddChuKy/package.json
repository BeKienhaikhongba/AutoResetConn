{
  "name": "signature-cropper",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"node server.js\"",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "pack": "vite build && electron-builder --dir",
    "build-exe": "vite build && electron-builder",
    "release": "node update-version.js && vite build && npx electron-packager . \"Tool Cut Image\" --platform=win32 --arch=x64 --out=release --overwrite --asar"
  },
  "build": {
    "appId": "com.signature.cropper",
    "productName": "Tool Cut Image",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "dir"
      ]
    },
    "files": [
      "dist/**/*",
      "server.js",
      "electron-main.js",
      "package.json",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.300.0",
    "pdfjs-dist": "^3.11.174",
    "pg": "^8.20.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-image-crop": "^10.1.8",
    "tesseract.js": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^5.0.8"
  }
}
